%%%%%%  CV STARTS HERE  %%%%%%%%%%%%%%%%%%%%%%%%%%%%


\begin{document}

%----------HEADING-----------------
\begin{tabular*}{\textwidth}{L@{\extracolsep{\fill}}C@{\extracolsep{\fill}}R}
  \href{mailto: {{contact.email}} }{ {{contact.email}} } &
  \multirow{2}{*}{\Huge \textbf{ {{contact.name}} }} &
  {% if contact.link %}\href{ {{contact.link}} }{ {{contact.linkDisplay}} }{% else %}{{contact.linkDisplay}}{% endif %} \\
  {{contact.phone}} & & {{contact.location}}
\end{tabular*}
\vspace{1pt}
\begin{center}
  \small {{contact.title}}
\end{center}
\vspace{2pt}
\noindent\small {{summary}}
\vspace{-4pt}


{% if skills.length %}
%--------PROGRAMMING SKILLS------------
\section{Skills}
\begin{tabular}{@{}l l@{}}
{% for cat in skills %}
  \textbf{ {{cat.category}} } & {{ cat.items | join(', ') }} \\
{% endfor %}
\end{tabular}

{% endif %}

{% if experience.length %}
%-----------EXPERIENCE-----------------
\section{Work Experience}
  \resumeSubHeadingListStart
  {% for job in experience %}
    \resumeSubheading
      { {{job.org}} }{ {{job.location}} }
      { {{job.role}} }{ {{job.date}} }
      {%- if job.bullets.length %}
        \resumeItemListStart
        {%- for bullet in job.bullets %}
        \resumeItemNH{ {{bullet}} }
        {%- endfor %}
        \resumeItemListEnd
      \vspace{-5pt}
      {%- endif %}
  {% endfor %}
  \resumeSubHeadingListEnd

{% endif %}


{% if research.length %}
%-----------Research and Publications-----------------
\section{Research and Publications}
  \resumeSubHeadingListStart
  {% for item in research %}
    \resumeSubheading
      { {{item.org}} }{ {{item.location if item.location is defined else ''}} }
      { {{item.role}} -- {{item.title}} }{ {{item.stack if item.stack is defined else ''}} }
      \resumeItemListStart
        \resumeItemNH{ {{item.description}} }
      \resumeItemListEnd
  {% endfor %}
  \resumeSubHeadingListEnd
{% endif %}


{% if projects.length %}
%-----------PROJECTS-----------------
\section{Projects}
  \resumeSubHeadingListStartBullets
  {% for project in projects %}
    \resumeSubItem{ {{project.name}} }{ {{project.description}} }
  {% endfor %}
  \resumeSubHeadingListEnd

{% endif %}

{% if involvement.length %}
\section{Involvement}
  \resumeSubHeadingListStartBullets
  {% for item in involvement %}
    \resumeSubItem{ {{item.name}} }{ {{item.description}} }
  {% endfor %}
  \resumeSubHeadingListEnd
{% endif %}

{% if education.length %}
%-----------EDUCATION-----------------
\section{Education}
  \resumeSubHeadingListStart
  {% for edu in education %}
    \resumeSubheading
      { {{edu.school}} }{ {{edu.location}} }
      { {{edu.degree}} }{ {{edu.date}} }
      \resumeItemListStart
        {% if edu.gpa %}\resumeItem{GPA}{ {{edu.gpa}} }{% endif %}
        {% if edu.honors %}\resumeItem{Honors}{ {{edu.honors}} }{% endif %}
        {% if edu.coursework %}\resumeItem{Coursework}{ {{edu.coursework}} }{% endif %}
      \resumeItemListEnd
  {% endfor %}
  \resumeSubHeadingListEnd
{% endif %}


%-------------------------------------------
\end{document}
