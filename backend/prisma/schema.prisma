generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  name                 String
  passwordHash         String?
  googleId             String?         @unique
  gmailConnected       Boolean         @default(false)
  gmailRefreshToken    String?
  gmailLastScannedAt   DateTime?
  ghostedThresholdDays Int             @default(21)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  applications         Application[]
  resumeVersions       ResumeVersion[]
  resumeProfile        ResumeProfile?
}

model Application {
  id           String        @id @default(cuid())
  userId       String
  company      String
  position     String
  location     String?
  stage        Stage         @default(applied)
  source       Source        @default(manual)
  appliedAt    DateTime      @default(now())
  lastUpdate   DateTime      @default(now())
  salary       String?
  notes        String?
  ghosted      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  statusEvents StatusEvent[]

  @@index([userId])
  @@index([userId, stage])
}

model StatusEvent {
  id            String      @id @default(cuid())
  applicationId String
  type          EventType
  label         String
  source        Source
  detail        String?
  createdAt     DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ResumeVersion {
  id                  String   @id @default(cuid())
  userId              String
  latexSource         String
  label               String
  targetRole          String?
  jobDescription      String?
  selectionDescriptor Json?
  createdAt           DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ResumeProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  contact     Json     @default("[]")
  summary     Json     @default("[]")
  skills      Json     @default("[]")
  experience  Json     @default("[]")
  research    Json     @default("[]")
  projects    Json     @default("[]")
  involvement Json     @default("[]")
  education   Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Stage {
  applied
  oa
  interview
  offer
  rejected
  ghosted
}

enum Source {
  manual
  email
}

enum EventType {
  applied
  oa
  interview
  offer
  rejected
  note
  email
}
